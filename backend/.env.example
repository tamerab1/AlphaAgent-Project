# -------------------------------------------------------
# AlphaAgent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# --- Database ---
DATABASE_URL=postgresql://postgres:local_password@localhost:5432/alpha_agent_local

# --- AI ---
OPENAI_API_KEY=sk-...

# --- Exchange APIs (Binance / Bybit) ---
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_SECRET_KEY=your_exchange_secret_key_here

# --- Application ---
# Options: development | production
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Production (set automatically by Render.com) ---
# RENDER=true

# --- Docker Compose overrides (optional) ---
# POSTGRES_PASSWORD=local_password
# GRAFANA_PASSWORD=admin
