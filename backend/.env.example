# -------------------------------------------------------
# AlphaAgent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# --- Database ---
DATABASE_URL=postgresql://postgres:local_password@localhost:5432/alpha_agent_local

# --- AI ---
OPENAI_API_KEY=sk-...

# --- Market data (Phase 3) ---
# Live news headlines (optional; seed headlines are used when unset).
TAVILY_API_KEY=tvly-...
# Set to true to fetch live price/RSI (yfinance) and headlines (Tavily).
# Leave false for deterministic seed data — the reliable demo path.
MARKET_DATA_LIVE=false

# --- Exchange APIs (Binance / Bybit) ---
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_SECRET_KEY=your_exchange_secret_key_here

# --- Application ---
# Options: development | production
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Production (set automatically by Render.com) ---
# RENDER=true

# --- Docker Compose overrides (optional) ---
# POSTGRES_PASSWORD=local_password
# GRAFANA_PASSWORD=admin
